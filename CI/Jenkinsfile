/* Jenkins CI: сборка Docker-образа и push в Docker Hub.
 *
 * Рекомендуемая настройка job:
 * - Multibranch Pipeline (GitHub/GitLab), default branch: main
 * - Webhook на PR events (opened/synchronize/reopened)
 *
 * Credentials:
 * - dockerhub (Username with password), credentialsId: dockerhub
 *
 * Важно: для корректного /health внутри образа нужен файл модели:
 *   experiments/tfidf_log_reg.pkl
 * Если модель не в git — добавьте шаг загрузки артефакта до docker build,
 * либо используйте CD с bind-mount модели (см. CD/Jenkinsfile).
 */

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds(abortPrevious: true)
    }

    parameters {
        string(name: 'DOCKER_NAMESPACE', defaultValue: 'YOUR_DOCKERHUB_USER', description: 'Docker Hub namespace/user')
        string(name: 'IMAGE_NAME', defaultValue: 'mle-template-api', description: 'Имя репозитория образа на Docker Hub')
        string(name: 'DOCKER_REGISTRY', defaultValue: 'docker.io', description: 'Реестр (обычно docker.io)')
        booleanParam(name: 'TRIGGER_CD', defaultValue: false, description: 'После успешного push запустить CD job')
        string(name: 'CD_JOB', defaultValue: '', description: 'Имя CD job в Jenkins (например folder/cd-mle-api). Пусто = не запускать')
        string(name: 'CD_DEPLOY_TAG', defaultValue: '', description: 'Тег образа для CD (пусто = использовать тег из CI)')
    }

    environment {
        DOCKERHUB = credentials('dockerhub')
    }

    stages {
        stage('Preflight') {
            steps {
                script {
                    if (!env.CHANGE_ID) {
                        echo 'INFO: CHANGE_ID пустой — это не PR-сборка Multibranch. Для автоматизации по PR используйте Multibranch Pipeline + webhook.'
                    }
                }
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify model artifact (recommended)') {
            steps {
                sh '''
                    test -f experiments/tfidf_log_reg.pkl || (echo "ERROR: experiments/tfidf_log_reg.pkl not found in workspace. Add artifact fetch/train step before docker build." && exit 1)
                '''
            }
        }

        stage('Docker build') {
            steps {
                script {
                    withEnv([
                        "IMAGE_NAME=${params.IMAGE_NAME}",
                    ]) {
                        sh '''
                            set -eux
                            SHORT_SHA="$(git rev-parse --short HEAD)"
                            docker build -t "${IMAGE_NAME}:ci-${BUILD_NUMBER}-${SHORT_SHA}" .
                        '''
                    }
                }
            }
        }

        stage('Docker login + push (PR -> main)') {
            when {
                allOf {
                    changeRequest()
                    equals expected: 'main', actual: "${env.CHANGE_TARGET}"
                }
            }
            steps {
                script {
                    withEnv([
                        "DOCKER_REGISTRY=${params.DOCKER_REGISTRY}",
                        "DOCKER_NAMESPACE=${params.DOCKER_NAMESPACE}",
                        "IMAGE_NAME=${params.IMAGE_NAME}",
                    ]) {
                        sh '''
                            set -eux
                            SHORT_SHA="$(git rev-parse --short HEAD)"
                            TAG_PR="pr-${CHANGE_ID}-${BUILD_NUMBER}-${SHORT_SHA}"

                            docker tag "${IMAGE_NAME}:ci-${BUILD_NUMBER}-${SHORT_SHA}" "${DOCKER_NAMESPACE}/${IMAGE_NAME}:${TAG_PR}"
                            docker tag "${IMAGE_NAME}:ci-${BUILD_NUMBER}-${SHORT_SHA}" "${DOCKER_NAMESPACE}/${IMAGE_NAME}:latest"

                            echo "${DOCKERHUB_PSW}" | docker login "${DOCKER_REGISTRY}" -u "${DOCKERHUB_USR}" --password-stdin

                            docker push "${DOCKER_NAMESPACE}/${IMAGE_NAME}:${TAG_PR}"
                            docker push "${DOCKER_NAMESPACE}/${IMAGE_NAME}:latest"

                            echo "PUSHED: ${DOCKER_REGISTRY}/${DOCKER_NAMESPACE}/${IMAGE_NAME}:${TAG_PR}"
                            echo "TAG_PR=${TAG_PR}" > ci_tags.env
                        '''
                    }
                }
            }
        }

        stage('Trigger CD') {
            when {
                allOf {
                    expression { return params.TRIGGER_CD.toBoolean() }
                    expression { return params.CD_JOB?.trim() }
                    changeRequest()
                    equals expected: 'main', actual: "${env.CHANGE_TARGET}"
                }
            }
            steps {
                script {
                    def tag = params.CD_DEPLOY_TAG?.trim()
                    if (!tag) {
                        def props = readFile('ci_tags.env').split('\n').find { it.startsWith('TAG_PR=') }
                        tag = props?.replace('TAG_PR=', '')?.trim()
                    }
                    if (!tag) {
                        error('Cannot resolve tag for CD (ci_tags.env missing TAG_PR?)')
                    }

                    build job: params.CD_JOB.trim(), wait: false, parameters: [
                        string(name: 'IMAGE_NAME', value: params.IMAGE_NAME),
                        string(name: 'DOCKER_NAMESPACE', value: params.DOCKER_NAMESPACE),
                        string(name: 'DOCKER_REGISTRY', value: params.DOCKER_REGISTRY),
                        string(name: 'IMAGE_TAG', value: tag),
                        booleanParam(name: 'RUN_FUNCTIONAL_TESTS', value: true),
                        booleanParam(name: 'KEEP_CONTAINER', value: false)
                    ]
                }
            }
        }
    }

    post {
        always {
            script {
                withEnv(["DOCKER_REGISTRY=${params.DOCKER_REGISTRY}"]) {
                    sh '''
                        docker logout "${DOCKER_REGISTRY}" || true
                    '''
                }
            }
        }
    }
}
